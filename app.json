{
  "expo": {
    "name": "Nook",
    "slug": "nook",
    "version": "1.2.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": [
      "nook",
      "com.hyerimhan.nook"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hyerimhan.nook",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "youtube",
          "instagram",
          "twitter",
          "naversearchapp",
          "naverblog",
          "kakaotalk",
          "fb",
          "tiktok",
          "linkedin",
          "threads",
          "notion"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F2F2F2",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1
          }
        }
      ],
      "expo-font",
      "expo-notifications",
      "expo-image"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f9e3f2df-f0df-4d35-b7a3-15bc1169f33c"
      }
    }
  }
}
